{
    "name": "maximaam/alamouriska",
    "description": "Mots algériens",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "beberlei/doctrineextensions": "^1.5",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0.0",
        "doctrine/orm": "^3.6.7",
        "easycorp/easyadmin-bundle": "^5.0.9",
        "knplabs/knp-menu-bundle": "^3.7",
        "knplabs/knp-paginator-bundle": "^6.10.0",
        "knpuniversity/oauth2-client-bundle": "^2.20.2",
        "league/oauth2-google": "^4.2.0",
        "liip/imagine-bundle": "^2.17.1",
        "phpstan/phpdoc-parser": "^2.3.2",
        "stof/doctrine-extensions-bundle": "^1.15.3",
        "symfony/asset": "^8.0.8",
        "symfony/asset-mapper": "^8.0.11",
        "symfony/console": "^8.0.11",
        "symfony/doctrine-messenger": "^8.0.6",
        "symfony/dotenv": "^8.0.11",
        "symfony/expression-language": "^8.0.8",
        "symfony/flex": "^2.10.0",
        "symfony/form": "^8.0.9",
        "symfony/framework-bundle": "^8.0.11",
        "symfony/google-mailer": "^8.0.0",
        "symfony/http-client": "^8.0.9",
        "symfony/intl": "^8.0.8",
        "symfony/mailer": "^8.0.12",
        "symfony/mime": "^8.0.12",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/notifier": "^8.0.8",
        "symfony/object-mapper": "^8.0.9",
        "symfony/process": "^8.0.11",
        "symfony/property-access": "^8.0.8",
        "symfony/property-info": "^8.0.8",
        "symfony/runtime": "^8.0.12",
        "symfony/security-bundle": "^8.0.12",
        "symfony/serializer": "^8.0.10",
        "symfony/stimulus-bundle": "^2.35",
        "symfony/string": "^8.0.11",
        "symfony/translation": "^8.0.10",
        "symfony/twig-bundle": "^8.0.8",
        "symfony/ux-icons": "^2.35",
        "symfony/ux-turbo": "^2.35",
        "symfony/validator": "^8.0.10",
        "symfony/web-link": "^8.0.8",
        "symfony/yaml": "^8.0.12",
        "symfonycasts/reset-password-bundle": "^1.25.0",
        "symfonycasts/verify-email-bundle": "^1.18.0",
        "twig/extra-bundle": "^2.12|^3.24.0",
        "twig/twig": "^2.12|^3.26.0",
        "vich/uploader-bundle": "^2.9.2"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "friendsofphp/php-cs-fixer": "^3.95.2",
        "phpstan/phpstan": "^2.1.55",
        "phpstan/phpstan-doctrine": "^2.0.22",
        "phpstan/phpstan-strict-rules": "^2.0.11",
        "phpunit/phpunit": "^13.1.12",
        "rector/rector": "^2.4.4",
        "symfony/browser-kit": "^8.0.8",
        "symfony/css-selector": "^8.0.9",
        "symfony/debug-bundle": "^8.0.8",
        "symfony/maker-bundle": "^1.67.0",
        "symfony/phpunit-bridge": "^8.0.8",
        "symfony/stopwatch": "^8.0.8",
        "symfony/web-profiler-bundle": "^8.0.12"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        },
        "replace": {
            "symfony/polyfill-ctype": "*",
            "symfony/polyfill-iconv": "*",
            "symfony/polyfill-php72": "*",
            "symfony/polyfill-php73": "*",
            "symfony/polyfill-php74": "*",
            "symfony/polyfill-php80": "*",
            "symfony/polyfill-php81": "*",
            "symfony/polyfill-php82": "*"
        },
        "scripts": {
            "auto-scripts": {
                "cache:clear": "symfony-cmd",
                "assets:install %PUBLIC_DIR%": "symfony-cmd",
                "importmap:install": "symfony-cmd"
            },
            "post-install-cmd": [
                "@auto-scripts"
            ],
            "post-update-cmd": [
                "@auto-scripts"
            ],
            "static-code-check": [
                "@cs-fixer:check",
                "@phpstan:check",
                "@rector:check",
                "@phpunit"
            ],
            "cs-fixer:fix": "php vendor/bin/php-cs-fixer fix",
            "cs-fixer:check": "php vendor/bin/php-cs-fixer fix --dry-run --diff",
            "phpstan:check": "phpstan analyse",
            "rector:check": "php vendor/bin/rector process --dry-run",
            "rector:fix": "php vendor/bin/rector process",
            "phpunit": "php bin/phpunit"
        },
        "conflict": {
            "symfony/symfony": "*"
        },
        "extra": {
            "symfony": {
                "allow-contrib": false,
                "require": "^8.0"
            }
        }
    }
}
