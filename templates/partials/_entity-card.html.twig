{% set entity_type = entity_type(entity) %}

<div class="card mb-3 card-post">
    <div class="card-header">
        <div class="d-inline-block align-middle">
            {% include 'partials/_avatar.html.twig' with {'pseudo': entity.pseudo, 'avatarName': entity.avatarName, 'size': 64 } only %}
        </div>
        <div class="d-inline-block align-middle">
            <a href="{{ path('app_frontend_member_profile', {'pseudo': entity.pseudo}) }}" title="{{ 'label.profile'|trans }}" class="fw-bold">
                {{ entity.pseudo }}
            </a>
            <br>
            <time class="" datetime="{{ entity.createdAt | date('Y.m.d H:i') }}">
                {{ 'label.date_on' | trans }} : {{ entity.createdAt }}
            </time>
        </div>
    </div>
    <div class="card-body p-2">
        {{ include ('partials/_entity-card-'~ entity_type ~'.html.twig') }}

        {% if app.user is not null and app.user.pseudo == entity.pseudo %}
            <div class="text-end">
                <a href="{{ path('app_' ~ entity.entityName ~ '_delete', {'id': entity.id} ) }}">{{ 'label.delete' | trans }}</a>
                |
                <a href="{{ path('app_' ~ entity.entityName ~ '_edit', {'id': entity.id} ) }}">{{ 'label.edit' | trans }}</a>
            </div>
        {% endif %}

        <div class="card-footer" {{ stimulus_controller('user-interactions', {
            csrfToken: app.user ? csrf_token('user-interactions') : '',
            entityId: entity.id,
            likeUrl: path('app_async_user_like', { 'id': entity.id, 'entityName': entity_type }),
            commentUrl: path('app_async_user_comment', { 'id': entity.id, 'entityName': entity_type }),
        }) }}>
            {{ include ('partials/_user-interactions.html.twig') }}
        </div>
    </div>

</div>
